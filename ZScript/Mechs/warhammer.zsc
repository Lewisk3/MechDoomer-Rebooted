class Warhammer_LeftTorso : MechSideTorso
{
   Default
   {
      Radius 10;
      Height 30;
      MechHardpoint.UIGraphics "paperdoll_LT.png", "paperdoll_SK_LT.png";
      
      MechHardpoint.Vitals 28, 14;
      MechHardpoint.SetupArmor 22, 6;
      MechHardpoint.RearArmor true;
   }
      
	override void SetupMounts()
	{
		AddMountPoint("Ballistic", 20,1,22.5, 1.0);
		AddMountPoint("Energy", 20, -2, 14, 0.65);
		AddMountPoint("Energy", 20,  4, 14, 0.65);
	}
}
class Warhammer_RightTorso : MechSideTorso
{
	Default
	{
	  Radius 10;
	  Height 50;
	  MechHardpoint.UIGraphics "paperdoll_RT.png", "paperdoll_SK_RT.png";
	  
	  MechHardpoint.Vitals 28, 14;
	  MechHardpoint.SetupArmor 22, 6;
	  MechHardpoint.RearArmor true;
	}  

	override void SetupMounts()
	{
		AddMountPoint("Ballistic", 20,-1,22.5, 1.0);
		AddMountPoint("Energy", 20,  2, 14, 0.65);
		AddMountPoint("Energy", 20, -4, 14, 0.65);
		SetupMountArray("Missile", -4,0.5,39, 2,3, 4.5,4, 0, 0.85);
	}
}

class Warhammer_LeftArm : MechArm
{
   Default
   {
      MechArm.ActuationRange 25;
      MechArm.PitchRange 25, 25;
      MechHardpoint.HitBox 10,35, 35,-11,-50;
      MechHardpoint.UIGraphics "paperdoll_LA.png", "paperdoll_SK_LA.png";

      MechHardpoint.Vitals 20, 10;
      MechHardpoint.SetupArmor 20, 0;
   }

	override void SetupHitboxes()
	{
		double lr = -18;
		double ud = -28;
		double h = 20;
		AddHitBox(0, lr + 7,ud + 16, 10, h);
		AddHitBox(0, lr,ud, 10, h);
		AddHitBox(15,lr,ud + 1, 10, h * 0.90);
		AddHitBox(35,lr,ud + 2, 10, h * 0.80);
		AddHitBox(55,lr,ud + 3, 10, h * 0.70);
		AddHitBox(70,lr,ud + 4, 6, h * 0.60);
	}

	override void SetupMounts()
	{
		AddMountPoint("Energy", 72, -20, -17, 0.45);
	}
}

class Warhammer_RightArm : Warhammer_LeftArm 
{
	Default
	{
	  MechHardpoint.HitBox 10,20, 35,11,-33;
	  MechHardpoint.UIGraphics "paperdoll_RA.png", "paperdoll_SK_RA.png";

	  MechHardpoint.Vitals 20, 10;
	  MechHardpoint.SetupArmor 20, 0;
	}
   
	override void SetupHitboxes()
	{
		double lr = 18;
		double ud = -28;
		double h = 20;
		AddHitBox(0, lr - 7,ud + 16, 10, h);
		AddHitBox(0, lr,ud, 10, h);
		AddHitBox(15,lr,ud + 1, 10, h * 0.90);
		AddHitBox(35,lr,ud + 2, 10, h * 0.80);
		AddHitBox(55,lr,ud + 3, 10, h * 0.70);
		AddHitBox(70,lr,ud + 4, 6, h * 0.60);
	}

	override void SetupMounts()
	{
		AddMountPoint("Energy", 72, 20, -17, 0.45);
	}
}
