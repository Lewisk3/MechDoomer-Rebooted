class MechWarhammer : DrivableMech
{
	Default
	{
		Radius 48;
		DrivableMech.Acceleration 27, 26;
		DrivableMech.MaxWeight 70; // In Tons.
		DrivableMech.ChassisName "Warhammer";
		DrivableMech.VariantName "6R";
		DrivableMech.ItemGraphic "Graphics/MechIcons/Warhammer_icon.png";
		DrivableMech.CBillValue (6023383  * MECHPRICESCALAR);
		
		DrivableMech.Manufacturer "StarCorps Industries";
	}
	
	override string getShopDescription()
	{
		return ( 
			"\c[White] The Warhammer BattleMech was introduced by StarCorps Industries in 2515 to "
			"be 'a mobile 'Mech with enough firepower to destroy or severely damage any "
			" 'Mech of the same weight class or lower.' In the mission it was designed for, "
			"the Warhammer proved to be a very capable 'Mech, and for centuries practically "
			"defined the entire class of heavy 'Mechs. Boasting incredible firepower and "
			"respectable armoring, the Warhammer served prominently in the Star League "
			"Defense Force and was one of the premier 'Mechs in the Gunslinger Program. "
			"(Source: https://www.sarna.net/wiki/Warhammer)"
		);
	}
   
	override void SetupParts()
	{
		super.SetupParts();

		legs  = AddMechPart("Warhammer_Legs",  0,0,0,  self);
		hips  = AddMechPart("Warhammer_Hips",  0,0,42, legs);

		// Hardpoints
		torso      = AddHardpoint("Warhammer_CenterTorso", 0,0,8, hips);
		leftTorso  = AddHardpoint("Warhammer_LeftTorso",  0,-20,0, torso);
		rightTorso = AddHardpoint("Warhammer_RightTorso", 0, 20,0, torso);

		leftLeg = AddHardpoint("Warhammer_LeftLeg",  0, -20,0, legs);
		rightLeg = AddHardpoint("Warhammer_RightLeg", 0, 20,0, legs);
		 
		leftArm  = AddHardpoint("Warhammer_LeftArm",  0,-10,20, leftTorso);
		rightArm = AddHardpoint("Warhammer_RightArm", 0, 10,20, rightTorso);

		head = AddHardpoint("Warhammer_Cockpit", 0,0,28, torso);
		cam  = AddPart("CockpitCamera", 15,0,0, head);
	}

	override void SetupItems()
	{  
		// Armor and Engine
		torso.AddItem("MechEngine_XL340");
		MechArmor.addToMech(self, "MechArmor_Standard");

		rightTorso.AddWeapon("MachineGun", GROUPFLG_THREE);
		rightTorso.AddWeapon("MediumLaser", GROUPFLG_TWO);
		rightTorso.AddWeapon("SRM6", GROUPFLG_FOUR);
		rightTorso.AddWeapon("SmallLaser", GROUPFLG_TWO);
		leftTorso.AddWeapon("MachineGun", GROUPFLG_THREE);
		leftTorso.AddWeapon("MediumLaser", GROUPFLG_TWO);
		leftTorso.AddWeapon("SmallLaser", GROUPFLG_TWO);
		rightArm.AddWeapon("PPC", GROUPFLG_ONE);
		leftArm.AddWeapon("PPC", GROUPFLG_ONE);
		SetChainFire(1, true);
		
		torso.AddItem("MGAmmo");
		torso.AddItem("MGAmmo");
		rightTorso.AddItem("SRMAmmo", GROUPFLG_ONE);
		leftArm.AddItem("MechHeatsink");
		rightArm.AddItem("MechHeatsink");
		leftTorso.AddItem("MechHeatsink");
		rightTorso.AddItem("MechHeatsink");
		leftLeg.AddItem("MechHeatsink");
		leftLeg.AddItem("MechHeatsink");
		rightLeg.AddItem("MechHeatsink");
		rightLeg.AddItem("MechHeatsink");
		head.AddItem("MechHeatsink");
	}
}

// (10 tons) Armor PTS
/*
	200pts 
	
	[HD] - 12
	[CT] - 40
	[LT] - 28
	[RT] - 28
	[LA] - 20
	[RA] - 20
	[LL] - 26
	[RL] - 26
*/


class Warhammer_Hips : MechHips {}
