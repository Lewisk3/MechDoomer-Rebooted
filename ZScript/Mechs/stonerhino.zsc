class StoneRhino_LeftArm : MechArm
{
   Default
   {
      MechArm.ActuationRange 30;
      MechArm.PitchRange 30, 30;
      MechHardpoint.UIGraphics "paperdoll_LA.png", "paperdoll_SK_LA.png";

      MechHardpoint.Vitals 33, 17;
      MechHardpoint.SetupArmor 33, 0;
   }

	override void SetupHitboxes()
	{
		AddHitBoxRect(60,-25,-30, 160,12,26);
		AddHitboxRect(0,0,-15, 10,20,30);
	}

	override void SetupMounts()
	{
		// 2B, 2E
		AddMountPoint("Ballistic", 140,-23,-18.5, scale:1.0);
		AddMountPoint("Ballistic", 105,-32,-10.75, scale:0.7);
		AddMountPoint("Energy", 60,-31,-25.25, scale:0.6);
		AddMountPoint("Energy", 80,-14.15,-25.65, scale:0.45);
	}
}

