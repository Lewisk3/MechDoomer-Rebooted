      MechTorso.TurnRange 85;
      MechTorso.PitchRange 30, 30;
      
      MechHardpoint.Vitals 60, 30;
      MechHardpoint.SetupArmor 46, 14;
      MechHardpoint.RearArmor true;
   }  
   
	override void SetupMounts()
	{
	}
}

class Battlemaster_LeftTorso : MechSideTorso
{
   Default
   {
      Radius 0; Height 0;
	  MechHardpoint.HitBox 9,40, 0,2,-8;
      MechHardpoint.UIGraphics "paperdoll_LT.png", "paperdoll_SK_LT.png";
      
      MechHardpoint.Vitals 42, 21;
      MechHardpoint.SetupArmor 34, 8;
      MechHardpoint.RearArmor true;
   }
      
	override void SetupMounts()
	{
		AddMountPoint("Energy", 14,12,8, 0.8);
		AddMountPoint("Energy", 14,4,8, 0.8);
		AddMountPoint("Energy", 12,8,5, 0.8);
		AddMountPoint("PDS", -9, 4, 24.25, 1.0);
	}
}
class Battlemaster_RightTorso : MechSideTorso
{
	Default
	{
	  Radius 0; Height 0;
	  MechHardpoint.HitBox 9,40, 0,-2,-8;
	  MechHardpoint.UIGraphics "paperdoll_RT.png", "paperdoll_SK_RT.png";
	  
