	}
}

class Battlemaster_LeftArm : MechArm
{
   Default
   {
      MechArm.ActuationRange 40;
      MechArm.PitchRange 30, 30;
      MechHardpoint.HitBox 10,20, 35,-16,-33;
      MechHardpoint.UIGraphics "paperdoll_LA.png", "paperdoll_SK_LA.png";

      MechHardpoint.Vitals 30, 15;
      MechHardpoint.SetupArmor 30, 0;
   }

	override void SetupHitboxes()
	{
		super.SetupHitboxes();
		AddHitBox(55,-16,-33, 10, 20);
		AddHitBox(20,-16,-33, 10, 20);
		AddHitBox(0,-16,-33, 10, 20);
		AddHitBox(0,-16,-13, 10, 20);
	}

	override void SetupMounts()
	{
		AddMountPoint("Ballistic", 57,-23.5,-19.5, 1.0);
		AddMountPoint("Ballistic", 57,-23.5,-27.5, 1.0);
	}
}

class Battlemaster_RightArm : Battlemaster_LeftArm 
{
	Default
	{
	  MechHardpoint.UIGraphics "paperdoll_RA.png", "paperdoll_SK_RA.png";

	  MechHardpoint.Vitals 30, 15;
	  MechHardpoint.SetupArmor 30, 0;
	}
   
	override void SetupHitboxes()
	{
		AddHitBox(80, 16,-24, 10, 12);
		AddHitBox(65, 16,-26, 10, 15);
		AddHitBox(50, 16,-26, 10, 15);
		AddHitBox(35, 16,-33, 10, 20);
		AddHitBox(20, 16,-33, 10, 20);
		AddHitBox(0, 16,-33, 10, 20);
		AddHitBox(0, 16,-13, 10, 20);
	}

	override void SetupMounts()
	{
		AddMountPoint("Energy", 92,13.9,-14.5, 0.5);
	}
}