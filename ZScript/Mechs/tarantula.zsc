class Tarantula_LeftFrontLeg : MechLeg
{
	Default
	{
		Radius 0; Height 0;
		MechHardpoint.Vitals 10, 5;
		MechHardpoint.SetupArmor 10, 0;
		MechHardpoint.UIGraphics "paperdoll_LA.png", "paperdoll_SK_LA.png";
		MechHardpoint.UI_Name "Left Leg [F]";
	}	
	
	// Jank, but placing these hitboxes is monumentally tedious.
	void SetupLegHitboxes(double fw, double lr, double ud, double cnt, double ang, double zoffs, double stepSize, double stepSizeUD)
	{
		for(int i = 0; i < cnt; i++)
		{
			double step = -(i*stepSize);
			double stepUD = -(i*stepSizeUD);
			AddHitBox(
				fw+(step * cos(ang)), 
				lr+(step * sin(ang)), 
				(ud-stepUD)+zoffs, 
				4, 10
			); 
		}
	}
	
	void PopulateHitBoxes(double fw, double lr, double ang, double dir = 1)
	{
		double fw = fw;
		double ud = -10;
		double angOffs = ang;
		AddHitBox(fw,lr,ud, 6,36);
		SetupLegHitboxes(fw,lr,ud, 5, angOffs,30,7*dir,7*dir);
		SetupLegHitboxes(fw * 0.6,lr * 0.6,ud, 7, angOffs+180,60,7*-dir,4*-dir);
	}
	
	override void SetupHitBoxes()
	{
		PopulateHitBoxes(70, -60, -45);
	}
}
class Tarantula_RightFrontLeg : Tarantula_LeftFrontLeg 
{
	Default
	{
		Radius 0; Height 0;
		MechHardpoint.UIGraphics "paperdoll_RA.png", "paperdoll_SK_RA.png";

		MechHardpoint.Vitals 10, 5;
		MechHardpoint.SetupArmor 10, 0;
		MechHardpoint.UI_Name "Right Leg [F]";
	}
	
	override void SetupHitBoxes()
	{
		PopulateHitBoxes(70, 60, 45);
	}
}
class Tarantula_LeftLeg : Tarantula_LeftFrontLeg
{
	Default
	{
		Radius 0; Height 0;
		MechHardpoint.Vitals 10, 5;
		MechHardpoint.SetupArmor 10, 0;
		MechHardpoint.UI_Name "Left Leg [R]";
		MechHardpoint.UIGraphics "paperdoll_LL.png", "paperdoll_SK_LL.png";
	}	
	
	override void SetupHitBoxes()
	{
		PopulateHitBoxes(-70, -60, 225);
	}
	
	override double GetMovePenalty()
	{
		double cur = super.getMovePenalty();
	
		let frontLeg = MechLeg(mech.leftArm);
		if(frontLeg) cur += frontLeg.getMovePenalty();
		return cur * 0.5;
	}
}
class Tarantula_RightLeg : Tarantula_LeftFrontLeg
{
	Default
	{
		Radius 0; Height 0;
		MechHardpoint.Vitals 10, 5;
		MechHardpoint.SetupArmor 10, 0;
		MechHardpoint.UI_Name "Right Leg [R]";
		MechHardpoint.UIGraphics "paperdoll_RL.png", "paperdoll_SK_RL.png";
	}	
	
	override void SetupHitBoxes()
	{
		PopulateHitBoxes(-70, 60, 135);
	}
	
	override double GetMovePenalty()
	{
		double cur = super.getMovePenalty();
	
		let frontLeg = MechLeg(mech.rightArm);
		if(frontLeg) cur += frontLeg.getMovePenalty();
		return cur * 0.5;
	}
}