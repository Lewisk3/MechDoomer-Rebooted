   {
      // Head component
      Radius 5;
      Height 3;
      MechHardpoint.Vitals 12, 6;
      MechHardpoint.SetupArmor 12, 0;
	  MechCockpit.Model "DirewolfCockpitModel";
   }
   
	override void SetupMounts()
	{
	}
}
class DirewolfCockpitModel : MechCockpitModel {}

