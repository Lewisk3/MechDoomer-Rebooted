class Direwolf_CenterTorso : MechTorso 
{
	Default
	{
	  MechTorso.TurnSpeed 68, 68;
	  MechTorso.TurnRange 90;
	  MechTorso.PitchRange 30, 30;
	  Radius 15;
	  Height 40;
	  
	  MechHardpoint.Vitals 78, 39;
	  MechHardpoint.SetupArmor 65, 13;
	  MechHardpoint.RearArmor true;
	}  
	
	override void SetupHitboxes()
	{
		super.SetupHitboxes();
		AddHitBox(20,0,0, 15, 40);
	}
   
	override void SetupMounts()
	{
	}
}

class Direwolf_LeftTorso : MechSideTorso
{
   Default
   {
      Radius 10;
      Height 40;
      MechHardpoint.UIGraphics "paperdoll_LT.png", "paperdoll_SK_LT.png";
      
      MechHardpoint.Vitals 55, 28;
      MechHardpoint.SetupArmor 45, 10;
      MechHardpoint.RearArmor true;
   }
      
	override void SetupMounts()
	{
		SetupMountArray("Missile", 7.25,-1,38.5, 4,2, 4.5,4, 7, 0.9);
	}
}
