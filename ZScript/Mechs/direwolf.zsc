class Direwolf_LeftArm : MechArm
{
   Default
   {
      MechArm.ActuationRange 0;
      MechArm.PitchRange 30, 30;
      MechHardpoint.HitBox 10,20, 35,-11,-50;
      MechHardpoint.UIGraphics "paperdoll_LA.png", "paperdoll_SK_LA.png";

      MechHardpoint.Vitals 40, 20;
      MechHardpoint.SetupArmor 40, 0;
   }

	override void SetupHitboxes()
	{
		double yshift = 2;
		AddHitBox(35,-11,-33 + yshift, 10, 20);
		AddHitBox(-8,-11,-12 + yshift, 12, 24);
		AddHitBox(0,-11,-33 + yshift, 10, 20);
		AddHitBox(15,-11,-33 + yshift, 10, 20);
	}

	override void SetupMounts()
	{
		AddMountPoint("Energy", 37,-8,-16.25, 0.85);
		AddMountPoint("Energy", 37,-7.5,-24.5, 0.85);
		
		AddMountPoint("Energy", 37,-8 - 13.5,-16.25, 0.85);
		AddMountPoint("Energy", 37,-7.5 - 13.5,-24.5, 0.85);
		
		AddMountPoint("Ballistic", 42, -14.5, -21, 1.0);
	}
}

class Direwolf_RightArm : Direwolf_LeftArm 
{
	Default
	{
	  MechHardpoint.HitBox 10,20, 35,11,-33;
	  MechHardpoint.UIGraphics "paperdoll_RA.png", "paperdoll_SK_RA.png";

	  MechHardpoint.Vitals 40, 20;
	  MechHardpoint.SetupArmor 40, 0;
	}
   
	override void SetupHitboxes()
	{
		double yshift = 2;
		AddHitBox(35,11,-33 + yshift, 10, 20);
		AddHitBox(-8,11,-12 + yshift, 12, 24);
		AddHitBox(0,11,-33 + yshift, 10, 20);
		AddHitBox(15,11,-33 + yshift, 10, 20);
	}

	override void SetupMounts()
	{
		AddMountPoint("Energy", 37,8,-16.25, 0.85);
		AddMountPoint("Energy", 37,7.5,-24.5, 0.85);
		
		AddMountPoint("Energy", 37,8 + 13.5,-16.25, 0.85);
		AddMountPoint("Energy", 37,7.5 + 13.5,-24.5, 0.85);
		
		AddMountPoint("Ballistic", 42, 14.5, -21, 1.0);
	}
}
