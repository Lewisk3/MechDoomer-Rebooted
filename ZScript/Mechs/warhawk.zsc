class MechWarhawk : DrivableMech
{
	Default
	{
		DrivableMech.Acceleration 25, 22;
		DrivableMech.MaxWeight 85; // In Tons.
		DrivableMech.ChassisName "Warhawk";
		DrivableMech.VariantName "Prime";
		DrivableMech.ItemGraphic "Graphics/MechIcons/Warhawk_icon.png";
		DrivableMech.CBillValue (26355948  * MECHPRICESCALAR);
		
		DrivableMech.Manufacturer "Imperial BattleMechs";
	}
	
	override string getShopDescription()
	{
		return ( 
			"\c[White] Deployed extensively in the Jaguar frontline forces, and "
			"often seen paired with the Dire Wolf, the design truly came into "
			"prominence on the battlefields of the Jaguars' Invasion Corridor, "
			"where it earned the code name of Masakari—a Japanese battle-axe "
			"used on medieval Terra—from the DCMS warriors who faced it. "
			"(Source: https://www.sarna.net/wiki/Warhawk_(Masakari))"
		);
	}
   
	override void SetupParts()
	{
		super.SetupParts();

		legs  = AddMechPart("Warhawk_Legs",  0,0,0,  self);
		hips  = AddMechPart("Warhawk_Hips",  0,0,55, legs);

		// Hardpoints
		torso      = AddHardpoint("Warhawk_CenterTorso", 0,0,7, hips);
		leftTorso  = AddHardpoint("Warhawk_LeftTorso",  0,-20,0, torso);
		rightTorso = AddHardpoint("Warhawk_RightTorso", 0, 20,0, torso);

		leftLeg = AddHardpoint("Warhawk_LeftLeg",  0, -20,0, legs);
		rightLeg = AddHardpoint("Warhawk_RightLeg", 0, 20,0, legs);
		 
		leftArm  = AddHardpoint("Warhawk_LeftArm",  0,-12,30, leftTorso);
		rightArm = AddHardpoint("Warhawk_RightArm", 0, 12,30, rightTorso);

		head = AddHardpoint("Warhawk_Cockpit", 38,0,18, torso);
		cam  = AddPart("CockpitCamera", 0,0,0, head);
	}

	override void SetupItems()
	{  
		// Armor and Engine
		torso.AddItem("MechEngine_XL340");
		MechArmor.addToMech(self, "MechArmor_ClanFerro");

		
		leftArm.AddWeapon("ERPPC", GROUPFLG_ONE);
		leftArm.AddWeapon("ERPPC", GROUPFLG_ONE);
		rightArm.AddWeapon("ERPPC", GROUPFLG_TWO);
		rightArm.AddWeapon("ERPPC", GROUPFLG_TWO);
		leftArm.AddWeapon("LRM10", GROUPFLG_THREE);
		leftArm.AddItem("LRMAmmo");
		rightTorso.AddItem("AMS");
		rightTorso.AddItem("AMSAmmo");
		SetChainfire(1, true);
		SetChainfire(2, true);
		
		rightArm.AddItem("MechDoubleHeatsink");
		rightTorso.AddItem("ImprovedHeatBank");
		rightTorso.AddItem("MechDoubleHeatsink");
		rightTorso.AddItem("MechDoubleHeatsink");
		leftTorso.AddItem("ImprovedHeatBank");
		leftTorso.AddItem("MechDoubleHeatsink");
	}
}

// (13.5 tons) Armor PTS
/*
	337pts 
	
[HD] - 12
[CT] - 71
[LT] - 50
[RT] - 50
[LA] - 32
[RA] - 32
[LL] - 45
[RL] - 45
*/


class Warhawk_Hips : MechHips {}
class Warhawk_Legs : MechLegs 
{
   Default
   {
      MechLegs.TurnSpeed 46;
   }
}

class Warhawk_Cockpit : MechCockpit 
{
   Default
   {
      // Head component
      Radius 5;
      Height 3;
      MechHardpoint.Vitals 12, 6;
      MechHardpoint.SetupArmor 12, 0;
	  MechCockpit.Model "WarhawkCockpitModel";
   }
   
	override void SetupMounts()
	{
	}
}
class WarhawkCockpitModel : MechCockpitModel {}

