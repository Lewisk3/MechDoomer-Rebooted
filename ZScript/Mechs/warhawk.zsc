class Warhawk_LeftArm : MechArm
{
   Default
   {
      MechArm.ActuationRange 20;
      MechArm.PitchRange 30, 30;
      MechHardpoint.HitBox 10,35, 35,-11,-50;
      MechHardpoint.UIGraphics "paperdoll_LA.png", "paperdoll_SK_LA.png";

      MechHardpoint.Vitals 32, 16;
      MechHardpoint.SetupArmor 32, 0;
   }

	override void SetupHitboxes()
	{
		AddHitBox(35,-11,-50, 10, 35);
		AddHitBox(-8,-11,-17, 10, 20);
		AddHitBox(0,-11,-33, 10, 20);
		AddHitBox(15,-11,-33, 10, 20);
		AddHitBox(55,-11,-33, 10, 20);
		AddHitBox(75,-11,-33, 10, 20);
	}

	override void SetupMounts()
	{
		AddMountPoint("Energy", 85, -17, -17, 0.5);
		AddMountPoint("Energy", 85, -5.5, -28, 0.5);
		
		SetupMountArray("Missile", 38, -15, -44, 3,5, 4.5,2.4, scale:0.8);
	}
}

class Warhawk_RightArm : Warhawk_LeftArm 
{
	Default
	{
	  MechHardpoint.HitBox 10,20, 35,11,-33;
	  MechHardpoint.UIGraphics "paperdoll_RA.png", "paperdoll_SK_RA.png";

	  MechHardpoint.Vitals 32, 16;
	  MechHardpoint.SetupArmor 32, 0;
	}
   
	override void SetupHitboxes()
	{
		AddHitBox(35,11,-33, 10, 20);
		AddHitBox(-8,11,-17, 10, 20);
		AddHitBox(0,11,-33, 10, 20);
		AddHitBox(15,11,-33, 10, 20);
		AddHitBox(55,11,-33, 10, 20);
		AddHitBox(75,11,-33, 10, 20);
	}

	override void SetupMounts()
	{
		AddMountPoint("Energy", 85, 17, -18, 0.5);
		AddMountPoint("Energy", 85, 5.5, -29, 0.5);
	}
}
