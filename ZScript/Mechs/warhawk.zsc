{
   Default
   {
      // Leg Stuff
      Radius 15;
      Height 60;
      MechHardpoint.Vitals 45, 23;
      MechHardpoint.SetupArmor 45, 0;
   }  
}
class Warhawk_RightLeg : MechRightLeg
{
   Default
   {
      // Leg Stuff
      Radius 15;
      Height 60;
      
      MechHardpoint.Vitals 45, 23;
      MechHardpoint.SetupArmor 45, 0;
   }  
}

class Warhawk_CenterTorso : MechTorso 
{
	Default
	{
	  MechTorso.TurnSpeed 85, 85;
	  MechTorso.TurnRange 90;
	  MechTorso.PitchRange 30, 30;
	  Radius 15;
	  Height 40;
	  
	  MechHardpoint.Vitals 71, 46;
	  MechHardpoint.SetupArmor 60, 11;
	  MechHardpoint.RearArmor true;
	}  
	
	override void SetupHitboxes()
	{
		super.SetupHitboxes();
		AddHitBox(20,0,0, 15, 40);
	}
   
	override void SetupMounts()
	{
	}
}

